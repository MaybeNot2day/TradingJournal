# Copy to .env.local and fill in. All values stay out of git.
# Hyperliquid wallet address the journal tracks
VITE_WALLET_ADDRESS=

# QFEX API keys (optional — leave empty to use Hyperliquid only).
# NOTE: VITE_ vars are bundled into the client JS. Anyone with the deployed
# URL can extract them. Fine for a private deployment; do not use on a public site.
VITE_QFEX_PUBLIC_KEY=
VITE_QFEX_SECRET_KEY=
